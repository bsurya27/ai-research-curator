# Reddit (create app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=script:your_app_name:v1.0

# Twitter (required for twscrape)
TWITTER_USERNAME=your_username
TWITTER_PASSWORD=your_password
TWITTER_EMAIL=your_email@example.com
TWITTER_EMAIL_PASSWORD=optional_for_imap_verification

# Apify (Reddit/Twitter actors — https://console.apify.com/account/integrations)
APIFY_API_TOKEN=your_token_here

# Twitter session cookies (Apify tweet-scraper and twscrape)
TWITTER_AUTH_TOKEN=your_auth_token_here
TWITTER_CT0=your_ct0_here
